			</geometry>
			<origin xyz="0.215 -0.07 0.31" rpy="0 0 0"></origin>
		</collision>
		<collision>
			<geometry>
				<sphere radius="0.066"></sphere>
			</geometry>
			<origin xyz="0.185 -0.135 0.31" rpy="0 0 0"></origin>
		</collision>
		<collision>
			<geometry>
				<sphere radius="0.066"></sphere>
			</geometry>
			<origin xyz="0.13 -0.185 0.31" rpy="0 0 0"></origin>
		</collision>
		<collision>
			<geometry>
				<sphere radius="0.066"></sphere>
			</geometry>
			<origin xyz="0.065 -0.2 0.31" rpy="0 0 0"></origin>
		</collision>
		<collision>
			<geometry>
				<sphere radius="0.066"></sphere>
			</geometry>
			<origin xyz="0.01 -0.2 0.31" rpy="0 0 0"></origin>
		</collision>

		<collision>
			<geometry>
